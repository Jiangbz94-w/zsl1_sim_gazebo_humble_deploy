    <model name="desk_drawer_handle">
      <static>true</static>
      <pose>5.3 12.63 0.55 0 0 0</pose>
      <link name="link">
        <visual name="vis">
          <geometry><cylinder><radius>0.008</radius><length>0.12</length></cylinder></geometry>
          <material><ambient>0.70 0.65 0.55 1</ambient><diffuse>0.70 0.65 0.55 1</diffuse><specular>0.9 0.85 0.65 120</specular></material>
        </visual>
      </link>
    </model>

