<?xml version="1.0"?>
<sdf version="1.6">
  <world name="study_room">

    <!-- ==================== Physics ==================== -->
    <physics type="ode">
      <real_time_update_rate>1000.0</real_time_update_rate>
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1</real_time_factor>
    </physics>

    <!-- ==================== Scene ==================== -->
    <scene>
      <ambient>0.58 0.56 0.54 1</ambient>
      <background>0.52 0.54 0.58 1</background>
      <shadows>false</shadows>
    </scene>

    <!-- ==================== Lighting ==================== -->
    <!-- 顶部天空光：垂直向下，无投影，模拟无天花板时均匀漫射日光 -->
    <light name="sky_light" type="directional">
      <cast_shadows>false</cast_shadows>
      <pose>7.5 7.5 10 0 0 0</pose>
      <diffuse>0.88 0.86 0.84 1</diffuse>
      <specular>0.20 0.20 0.18 1</specular>
      <direction>0 0 -1</direction>
    </light>

    <!-- ==================== Gazebo ROS State Plugin ==================== -->
    <plugin name="gazebo_ros_state" filename="libgazebo_ros_state.so">
      <ros>
        <namespace>/</namespace>
      </ros>
    </plugin>

    <!-- ==================================================
         ROOM STRUCTURE   15 m × 15 m × 4 m
         坐标原点在角落，房间覆盖 x∈[0,15] y∈[0,15] z∈[0,4]
         机器人出生点 ≈ (2,0)/(2,2)，紧靠南墙但无家具遮挡
    ================================================== -->

    <!-- -- Floor (木质地板) ---- -->
    <model name="floor">
      <static>true</static>
      <pose>7.5 7.5 -0.025 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry><box><size>15.0 15.0 0.05</size></box></geometry>
        </collision>
        <visual name="vis">
          <geometry><box><size>15.0 15.0 0.05</size></box></geometry>
          <material>
            <!-- Gazebo 内置木纹材质 -->
            <script>
              <uri>file://media/materials/scripts/gazebo.material</uri>
              <name>Gazebo/Wood</name>
            </script>
            <!-- 叠加暖棕色调，让地板更像实木深色款 -->
            <ambient>0.42 0.27 0.13 1</ambient>
            <diffuse>0.42 0.27 0.13 1</diffuse>
            <specular>0.18 0.10 0.04 30</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- ---- Ceiling (注释掉以便 Gazebo 俯视观察) ----
    <model name="ceiling">
      <static>true</static>
      <pose>7.5 7.5 4.025 0 0 0</pose>
      <link name="link">
        <visual name="vis">
          <geometry><box><size>15.0 15.0 0.05</size></box></geometry>
          <material>
            <ambient>0.94 0.93 0.90 1</ambient>
            <diffuse>0.94 0.93 0.90 1</diffuse>
          </material>
        </visual>
      </link>
    </model>
    -->

    <!-- ---- Wall South  y = 0 ---- -->
    <model name="wall_south">
      <static>true</static>
      <pose>7.5 -0.1 2.0 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>15.2 0.2 4.0</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>15.2 0.2 4.0</size></box></geometry>
          <material><ambient>0.93 0.91 0.86 1</ambient><diffuse>0.93 0.91 0.86 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- ---- Wall North  y = 15 ---- -->
    <model name="wall_north">
      <static>true</static>
      <pose>7.5 15.1 2.0 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>15.2 0.2 4.0</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>15.2 0.2 4.0</size></box></geometry>
          <material><ambient>0.93 0.91 0.86 1</ambient><diffuse>0.93 0.91 0.86 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- ---- Wall West   x = 0 ---- -->
    <model name="wall_west">
      <static>true</static>
      <pose>-0.1 7.5 2.0 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.2 15.0 4.0</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>0.2 15.0 4.0</size></box></geometry>
          <material><ambient>0.93 0.91 0.86 1</ambient><diffuse>0.93 0.91 0.86 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- ---- Wall East   x = 15 ---- -->
    <model name="wall_east">
      <static>true</static>
      <pose>15.1 7.5 2.0 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.2 15.0 4.0</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>0.2 15.0 4.0</size></box></geometry>
          <material><ambient>0.93 0.91 0.86 1</ambient><diffuse>0.93 0.91 0.86 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- ---- Baseboard / 踢脚线 South ---- -->
    <model name="baseboard_s">
      <static>true</static>
      <pose>7.5 0.09 0.08 0 0 0</pose>
      <link name="link">
        <visual name="vis">
          <geometry><box><size>15.0 0.02 0.15</size></box></geometry>
          <material><ambient>0.70 0.50 0.28 1</ambient><diffuse>0.70 0.50 0.28 1</diffuse><specular>0.2 0.15 0.08 20</specular></material>
        </visual>
      </link>
    </model>
    <model name="baseboard_n">
      <static>true</static>
      <pose>7.5 14.91 0.08 0 0 0</pose>
      <link name="link">
        <visual name="vis">
          <geometry><box><size>15.0 0.02 0.15</size></box></geometry>
          <material><ambient>0.70 0.50 0.28 1</ambient><diffuse>0.70 0.50 0.28 1</diffuse><specular>0.2 0.15 0.08 20</specular></material>
        </visual>
      </link>
    </model>
    <model name="baseboard_w">
      <static>true</static>
      <pose>0.09 7.5 0.08 0 0 0</pose>
      <link name="link">
        <visual name="vis">
          <geometry><box><size>0.02 15.0 0.15</size></box></geometry>
          <material><ambient>0.70 0.50 0.28 1</ambient><diffuse>0.70 0.50 0.28 1</diffuse><specular>0.2 0.15 0.08 20</specular></material>
        </visual>
      </link>
    </model>
    <model name="baseboard_e">
      <static>true</static>
      <pose>14.91 7.5 0.08 0 0 0</pose>
      <link name="link">
        <visual name="vis">
          <geometry><box><size>0.02 15.0 0.15</size></box></geometry>
          <material><ambient>0.70 0.50 0.28 1</ambient><diffuse>0.70 0.50 0.28 1</diffuse><specular>0.2 0.15 0.08 20</specular></material>
        </visual>
      </link>
    </model>

    <!-- ==================================================
         DESK   书桌  1.6 m × 0.75 m × 0.75 m
         位置: 北墙中左区域，x≈5, y≈13
    ================================================== -->

    <!-- 桌面 — 厚实木板，带倒角感用叠层 -->
    <model name="desk_top">
      <static>true</static>
      <pose>5.0 13.0 0.735 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>1.60 0.75 0.05</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>1.60 0.75 0.05</size></box></geometry>
          <material>
            <script>
              <uri>file://media/materials/scripts/gazebo.material</uri>
              <name>Gazebo/Wood</name>
            </script>
            <ambient>0.50 0.30 0.12 1</ambient>
            <diffuse>0.50 0.30 0.12 1</diffuse>
            <specular>0.50 0.35 0.15 60</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- 桌沿加厚条 (前) -->
    <model name="desk_edge_front">
      <static>true</static>
      <pose>5.0 12.645 0.705 0 0 0</pose>
      <link name="link">
        <visual name="vis">
          <geometry><box><size>1.60 0.04 0.04</size></box></geometry>
          <material><ambient>0.42 0.24 0.09 1</ambient><diffuse>0.42 0.24 0.09 1</diffuse><specular>0.4 0.28 0.10 80</specular></material>
        </visual>
      </link>
    </model>

    <!-- 桌面侧面封边 (左右) -->
    <model name="desk_edge_l">
      <static>true</static>
      <pose>4.185 13.0 0.705 0 0 0</pose>
      <link name="link">
        <visual name="vis">
          <geometry><box><size>0.04 0.75 0.04</size></box></geometry>
          <material><ambient>0.42 0.24 0.09 1</ambient><diffuse>0.42 0.24 0.09 1</diffuse><specular>0.4 0.28 0.10 80</specular></material>
        </visual>
      </link>
    </model>
    <model name="desk_edge_r">
      <static>true</static>
