      <static>true</static>
      <pose>4.22 13.0 0.355 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.05 0.70 0.71</size></box></geometry></collision>
        <visual name="vis">
          <geometry><box><size>0.05 0.70 0.71</size></box></geometry>
          <material><ambient>0.45 0.27 0.10 1</ambient><diffuse>0.45 0.27 0.10 1</diffuse><specular>0.35 0.22 0.08 50</specular></material>
        </visual>
